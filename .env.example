# IRG Reference — environment template
# Copy this file to `.env` at the repo root and fill in your own values.
# Both the API server (api-impl-js) and the trace navigator load from this file.

# ─── LLM Providers ───────────────────────────────────────────────────────────
# Set the API key for any provider you want to use. The API server
# auto-detects which providers are configured at startup. You don't have
# to set all of them — just the ones you want to use.
#
# At least one is required. If multiple are set, callers can pick by
# passing `provider` in the request body or by using a model name whose
# prefix maps to a provider (e.g. `gpt-*` → openai, `claude-*` → anthropic).

API_KEY_GROQ=
API_KEY_OPENAI=
API_KEY_ANTHROPIC=
API_KEY_MISTRAL=
API_KEY_GOOGLE=
API_KEY_TOGETHER=

# Local Ollama runs without an API key. Override the host if needed.
# OLLAMA_HOST=http://localhost:11434

# Optional: explicit allowlist of providers the server will accept and the
# trace-navigator will offer in its UI. Comma-separated, case-insensitive.
# Order matters: the first listed provider becomes the default when no
# provider is specified and no model-prefix match is found.
#
# Valid names: groq, openai, anthropic, mistral, google, together, ollama
#
# If unset, every provider with a configured API key is enabled.
# LLM_PROVIDERS_ENABLED=groq,anthropic,openai

# ─── Optional: API server tuning ─────────────────────────────────────────────

# Port for the IRG API server. Defaults to 2100 (see shared/runtime-defaults.json).
# IRG_API_PORT=2100

# Filesystem root for the fact-check store. Defaults to `<repo>/_fact-store/`.
# Used when `enableFactCheckPipeline=true` for citation persistence.
# FACT_STORE_ROOT=

# Embedding provider for semantic memory recall. Optional.
#   'openai'  use OpenAI text-embedding-3-small (requires API_KEY_OPENAI)
#   'hash'    deterministic local feature-hash embedder (no key required)
# If unset: 'openai' when API_KEY_OPENAI is configured, else 'hash'.
# EMBEDDINGS_PROVIDER=

# How often (in ms) the API server runs the background fact-store
# sweep that prunes expired citations. Set to 0 to disable the timer;
# a one-shot sweep still runs at startup. Default: 86400000 (24h).
# FACT_STORE_SWEEP_INTERVAL_MS=86400000

# Backend for semantic memory recall (the ClaimIndex). Optional.
#   'exact'  brute-force cosine over stored claim embeddings (default)
#   'lsh'    pure-JS banded random-hyperplane LSH (approximate, sub-linear)
#   'ss4'    delegate to an external SS4 sidecar (requires SS4_SIDECAR_URL)
# If unset: 'exact'.
# CLAIM_INDEX_BACKEND=exact

# URL of the SS4 retrieval sidecar (only used when CLAIM_INDEX_BACKEND=ss4).
# Expects POST {url}/query  { vector, top_k, threshold, exclude_key } ->
#   { neighbors: [ { claim_key, claim_text, domain, similarity, embedding_model } ] }
# SS4_SIDECAR_URL=

# ─── Required: Trace Navigator (Next.js app) ─────────────────────────────────

# Where the trace navigator forwards user queries.
# Set to your running API server's `/webhook/irg-process` endpoint.
IRG_ENDPOINT=http://localhost:2100/webhook/irg-process

# NextAuth — public URL the navigator runs at, and a secret for JWT signing.
# Generate a secret with: `openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:2000
NEXTAUTH_SECRET=

# Google OAuth credentials (used by the trace-navigator's sign-in flow,
# unrelated to the Gemini API key above).
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Required: Trace Navigator access allowlist ──────────────────────────────
# At least ONE of these must be set, or no one will be able to sign in.
# Both are comma-separated and case-insensitive.

# Email domains allowed to sign in (e.g. members of these orgs).
TRACE_NAVIGATOR_ALLOWED_DOMAINS=

# Specific email addresses allowed to sign in (overrides domain allowlist).
TRACE_NAVIGATOR_ALLOWED_EMAILS=
